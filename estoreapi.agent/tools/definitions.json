  {
    "name": "create_job",
    "description": "Create a new repair job.",
    "input_schema": {
      "type": "object",
      "properties": {
        "customerId": {
          "type": "integer",
          "description": "ID of the customer who owns the device."
        },
        "deviceId": {
          "type": "integer",
          "description": "ID of the device being repaired."
        },
        "receiveTime": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the device was received."
        },
        "pickupTime": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the device was picked up (optional)."
        },
        "estimatedPickupTime": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp for estimated pickup (optional)."
        },
        "note": {
          "type": "string",
          "description": "Additional notes about the job (optional)."
        },
        "problemIds": {
          "type": "array",
          "description": "List of problem IDs associated with this job (at least one required).",
          "items": {
            "type": "integer"
          },
          "minItems": 1
        },
        "estimatedPrice": {
          "type": "number",
          "description": "Estimated repair price (optional)."
        },
        "collectedPrice": {
          "type": "number",
          "description": "Amount collected from customer (optional)."
        },
        "isFinished": {
          "type": "boolean",
          "description": "Whether the job is complete. Defaults to false."
        }
      },
      "required": ["customerId", "deviceId", "receiveTime", "problemIds"]
    }
  },
  {
    "name": "create_jobs_bulk",
    "description": "Create multiple repair jobs in a single request.",
    "input_schema": {
      "type": "object",
      "properties": {
        "jobs": {
          "type": "array",
          "description": "List of jobs to create.",
          "items": {
            "type": "object",
            "properties": {
              "customerId": {
                "type": "integer",
                "description": "ID of the customer."
              },
              "deviceId": {
                "type": "integer",
                "description": "ID of the device."
              },
              "receiveTime": {
                "type": "string",
                "format": "date-time",
                "description": "ISO 8601 timestamp when the device was received."
              },
              "pickupTime": {
                "type": "string",
                "format": "date-time",
                "description": "ISO 8601 timestamp for actual pickup (optional)."
              },
              "estimatedPickupTime": {
                "type": "string",
                "format": "date-time",
                "description": "ISO 8601 timestamp for estimated pickup (optional)."
              },
              "note": {
                "type": "string",
                "description": "Additional notes (optional)."
              },
              "problemIds": {
                "type": "array",
                "description": "List of problem IDs (at least one required).",
                "items": {
                  "type": "integer"
                },
                "minItems": 1
              },
              "estimatedPrice": {
                "type": "number",
                "description": "Estimated repair price (optional)."
              },
              "collectedPrice": {
                "type": "number",
                "description": "Amount collected (optional)."
              },
              "isFinished": {
                "type": "boolean",
                "description": "Whether the job is complete. Defaults to false."
              }
            },
            "required": ["customerId", "deviceId", "receiveTime", "problemIds"]
          }
        }
      },
      "required": ["jobs"]
    }
  },
